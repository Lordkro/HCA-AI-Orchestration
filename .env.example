# ============================================================
# HCA Orchestration - Environment Configuration
# ============================================================
# Copy this file to .env and adjust values for your setup.
# ============================================================

# --- Ollama Configuration ---
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_DEFAULT_MODEL=qwen3:14b
OLLAMA_CODER_MODEL=qwen2.5-coder:14b
OLLAMA_TIMEOUT=120
OLLAMA_NUM_CTX=8192
OLLAMA_MAX_RETRIES=3
OLLAMA_RETRY_BASE_DELAY=2.0
OLLAMA_DEFAULT_TEMPERATURE=0.7
OLLAMA_DEFAULT_TOP_P=0.9

# --- Per-Agent Model Overrides (leave blank to use default) ---
OLLAMA_PM_MODEL=
OLLAMA_RESEARCH_MODEL=
OLLAMA_SPEC_MODEL=
OLLAMA_CODER_MODEL_OVERRIDE=
OLLAMA_CRITIC_MODEL=

# --- Per-Agent Temperature / Top_P (0 = use default; also see OLLAMA_DEFAULT_TEMPERATURE / OLLAMA_DEFAULT_TOP_P) ---
OLLAMA_PM_TEMPERATURE=0.0
OLLAMA_PM_TOP_P=0.0
OLLAMA_RESEARCH_TEMPERATURE=0.0
OLLAMA_RESEARCH_TOP_P=0.0
OLLAMA_SPEC_TEMPERATURE=0.0
OLLAMA_SPEC_TOP_P=0.0
OLLAMA_CODER_TEMPERATURE=0.0
OLLAMA_CODER_TOP_P=0.0
OLLAMA_CRITIC_TEMPERATURE=0.0
OLLAMA_CRITIC_TOP_P=0.0

# --- Redis Configuration ---
REDIS_URL=redis://redis:6379/0

# --- Database ---
DATABASE_URL=sqlite:///data/hca.db

# --- API Security ---
HCA_API_KEY=                   # Set to enable Bearer-token auth on all endpoints (except /metrics and health probes)
CORS_ORIGINS=https://app.example.com,http://localhost:5173

# --- Web UI ---
WEB_HOST=0.0.0.0
WEB_PORT=8080

# --- Orchestration Limits ---
MAX_ITERATIONS_PER_TASK=5
MAX_TASKS_PER_PROJECT=50
TASK_TIMEOUT_MINUTES=30
PROJECT_TIMEOUT_MINUTES=480

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json

# --- Workspace ---
WORKSPACE_DIR=/workspace
