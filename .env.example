# ============================================================
# HCA Orchestration - Environment Configuration
# ============================================================
# Copy this file to .env and adjust values for your setup.
# ============================================================

# --- Ollama Configuration ---
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_DEFAULT_MODEL=qwen2.5:32b
OLLAMA_CODER_MODEL=qwen2.5-coder:32b
OLLAMA_TIMEOUT=120
OLLAMA_NUM_CTX=8192
OLLAMA_MAX_RETRIES=3
OLLAMA_RETRY_BASE_DELAY=2.0

# --- Per-Agent Model Overrides (leave blank to use default) ---
OLLAMA_PM_MODEL=
OLLAMA_RESEARCH_MODEL=
OLLAMA_SPEC_MODEL=
OLLAMA_CODER_MODEL_OVERRIDE=
OLLAMA_CRITIC_MODEL=

# --- Redis Configuration ---
REDIS_URL=redis://redis:6379/0

# --- Database ---
DATABASE_URL=sqlite:///data/hca.db

# --- Web UI ---
WEB_HOST=0.0.0.0
WEB_PORT=8080

# --- Orchestration Limits ---
MAX_ITERATIONS_PER_TASK=5
MAX_TASKS_PER_PROJECT=50
TASK_TIMEOUT_MINUTES=30
PROJECT_TIMEOUT_MINUTES=480

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json

# --- Workspace ---
WORKSPACE_DIR=/workspace
