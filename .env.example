# ============================================================
# HCA Orchestration - Environment Configuration
# ============================================================
# Copy this file to .env and adjust values for your setup.
# ============================================================

# --- Ollama Configuration ---
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_DEFAULT_MODEL=qwen3:8b
OLLAMA_CODER_MODEL=qwen2.5-coder:7b
OLLAMA_TIMEOUT=120
OLLAMA_NUM_CTX=8192
OLLAMA_MAX_RETRIES=3
OLLAMA_RETRY_BASE_DELAY=2.0
OLLAMA_DEFAULT_TEMPERATURE=0.7
OLLAMA_DEFAULT_TOP_P=0.9
OLLAMA_MAX_CONCURRENT=1
OLLAMA_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
OLLAMA_CIRCUIT_BREAKER_RECOVERY_TIMEOUT=60

# --- Per-Agent Model Overrides (leave blank to use default) ---
OLLAMA_PM_MODEL=
OLLAMA_RESEARCH_MODEL=
OLLAMA_SPEC_MODEL=
OLLAMA_CODER_MODEL_OVERRIDE=
OLLAMA_CRITIC_MODEL=

# --- Per-Agent Temperature / Top_P (0 = use default; also see OLLAMA_DEFAULT_TEMPERATURE / OLLAMA_DEFAULT_TOP_P) ---
OLLAMA_PM_TEMPERATURE=0.0
OLLAMA_PM_TOP_P=0.0
OLLAMA_RESEARCH_TEMPERATURE=0.0
OLLAMA_RESEARCH_TOP_P=0.0
OLLAMA_SPEC_TEMPERATURE=0.0
OLLAMA_SPEC_TOP_P=0.0
OLLAMA_CODER_TEMPERATURE=0.0
OLLAMA_CODER_TOP_P=0.0
OLLAMA_CRITIC_TEMPERATURE=0.0
OLLAMA_CRITIC_TOP_P=0.0

# --- Hardware / Docker image selection ---
# Ollama Docker image tag (default: latest). Use "rocm" for AMD GPUs.
# The docker-compose.yml selects the image automatically based on
# the active profile (cpu / nvidia / rocm / vulkan / metal). Override here if needed.
#   CPU / NVIDIA → ollama/ollama:latest           (NVIDIA requires --profile nvidia)
#   AMD ROCm     → ollama/ollama:rocm             (--profile rocm)
#   Vulkan (any) → ollama/ollama:latest           (--profile vulkan)
#   Apple Metal  → ollama/ollama:latest (arm64)   (--profile metal)
# OLLAMA_IMAGE=ollama/ollama
# OLLAMA_TAG=latest

# --- GPU-specific overrides ---
# AMD ROCm: set HSA_OVERRIDE_GFX_VERSION to match your GPU's GFX IP.
#   Find yours: cat /sys/class/kfd/kfd/topology/nodes/0/properties | grep gfx
#   RX 7900 XTX/XT (RDNA3) = 11.0.0  (default)
#   RX 6900/6800/6700 (RDNA2) = 10.3.0
#   RX 5700/5600 (RDNA1) = 9.4.0
#   RX 6000 series (some) = 10.1.0
# HSA_OVERRIDE_GFX_VERSION=10.3.0
#
# AMD ROCm: select which GPU to use (default: first GPU)
# ROCR_VISIBLE_DEVICES=0
#
# NVIDIA: select which GPU to use (default: all GPUs)
# NVIDIA_VISIBLE_DEVICES=all

# --- Recommended model combinations by VRAM ---
# | VRAM    | Default model    | Coder model          | Quantization |
# |---------|------------------|----------------------|--------------|
# | ≥24 GB  | qwen3:14b        | qwen2.5-coder:14b   | Q4_K_M       |
# | 12-24 GB| qwen3:8b         | qwen2.5-coder:7b    | Q4_K_M       |
# | 8-12 GB | llama3.2:3b      | qwen2.5-coder:3b    | Q4_K_M       |
# | 6-8 GB  | phi-4:latest     | phi-4:latest        | Q4_K_M       |
# | <6 GB   | llama3.2:1b      | qwen2.5-coder:1.5b  | Q4_K_M       |
#
# Quantization can be appended with a colon suffix, e.g.: qwen3:8b:Q4_K_M
# See OLLAMA_MODELS_TO_PULL below to customise which models are pre-pulled.

# --- Redis Configuration ---
REDIS_URL=redis://redis:6379/0

# --- Database ---
DATABASE_URL=sqlite:///data/hca.db

# --- API Security ---
HCA_API_KEY=                   # Set to enable Bearer-token auth on all endpoints (except /metrics and health probes)
CORS_ORIGINS=https://app.example.com,http://localhost:5173

# --- Web UI ---
WEB_HOST=0.0.0.0
WEB_PORT=8080

# --- Orchestration Limits ---
MAX_ITERATIONS_PER_TASK=5
MAX_TASKS_PER_PROJECT=50
TASK_TIMEOUT_MINUTES=30
PROJECT_TIMEOUT_MINUTES=480
PROJECT_TOKEN_BUDGET=500000
ACTIVITY_TIMEOUT_MINUTES=60
MAX_PARALLEL_TASKS=3

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json

# --- Workspace ---
WORKSPACE_DIR=/workspace
WORKSPACE_RETENTION_DAYS=7
WORKSPACE_MAX_COUNT=100

# --- GitHub Integration ---
# Personal access token for pushing project workspaces to GitHub repos.
# Requires at least "repo" scope. Can be overridden per-request via API.
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# --- Model Puller ---
# Space-separated list of models to pre-pull when running
#   docker compose --profile setup run model-puller
# OLLAMA_MODELS_TO_PULL=qwen3:8b qwen2.5-coder:7b
